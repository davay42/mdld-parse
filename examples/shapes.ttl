
@prefix prov: <http://www.w3.org/ns/prov#>.
@prefix sh:   <http://www.w3.org/ns/shacl#>.
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#>.
@prefix mdld: <https://mdld.js.org/prov>.

###########
# Entity shape
###########

mdld:EntityShape
    a sh:NodeShape ;
    sh:targetClass prov:Entity ;
    sh:property [
        sh:path prov:value ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path prov:atLocation ;
        sh:maxCount 1 ;
    ] .

###########
# Activity shape
###########

mdld:ActivityShape
    a sh:NodeShape ;
    sh:targetClass prov:Activity ;
    sh:property [
        sh:path prov:used ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path prov:generated ;
        sh:minCount 1 ;
    ] .

###########
# Plan linkage shape
###########

mdld:PlanLinkShape
    a sh:NodeShape ;
    sh:targetSubjectsOf prov:hadPlan ;
    sh:class prov:Activity .

###########
# Derivation consistency
###########

mdld:DerivationShape
    a sh:NodeShape ;
    sh:targetSubjectsOf prov:wasDerivedFrom ;
    sh:class prov:Entity .
