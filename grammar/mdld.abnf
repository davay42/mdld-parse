; MD-LD ABNF Grammar (RFC 5234 compliant)
; Version: 1.1 (2024-05-04)
; Updated to match actual parser implementation
; - Added remove polarity (- prefix)
; - Added subject reset (= alone)
; - Added prefix folding (CURIE in context declarations)
; - Fixed predicate/object-predicate distinction
; - Fixed code fence matching (3+ backticks/tildes)
; Defines syntax of MD-LD annotations embedded in CommonMark Markdown

; Core RFC 5234 conventions
ALPHA      = %x41-5A / %x61-7a
DIGIT      = %x30-39
HEXDIG     = DIGIT / "A" / "B" / "C" / "D" / "E" / "F"
WSP        = SP / HTAB
SP         = %x20
HTAB       = %x09
LF         = %x0A
CR         = %x0D
CRLF       = CR LF
VCHAR      = %x21-7E

; MD-LD Grammar starts here

; 1. Context declarations
context-decl = "[" context-key "]" WSP "<" context-iri ">"
context-key  = "@" "vocab" / prefix-name
prefix-name  = ALPHA *( ALPHA / DIGIT / "-" / "_" )

; Prefix folding: IRI can be a CURIE referencing previously declared prefix
context-iri  = iri / curie

; 2. Attribute blocks
attrs-block = "{" *WSP [ attrs-tokens ] *WSP "}"
attrs-tokens = attrs-token *( 1*WSP attrs-token )

; 3. Attribute tokens (all support optional remove polarity)
attrs-token = 
      modified-subject-decl
    / modified-fragment-decl
    / modified-object-decl
    / modified-object-fragment-decl
    / modified-type-decl
    / modified-predicate
    / modified-object-predicate
    / modified-reverse-predicate
    / modified-datatype
    / modified-language

; Remove polarity modifier (prefix to any token)
remove-mod = "-"

; Modified tokens with optional remove
modified-subject-decl      = [ remove-mod ] subject-decl
modified-fragment-decl     = [ remove-mod ] fragment-decl
modified-object-decl       = [ remove-mod ] object-decl
modified-object-fragment-decl = [ remove-mod ] object-fragment-decl
modified-type-decl         = [ remove-mod ] type-decl
modified-predicate         = [ remove-mod ] predicate
modified-object-predicate  = [ remove-mod ] object-predicate
modified-reverse-predicate = [ remove-mod ] reverse-predicate
modified-datatype          = [ remove-mod ] datatype
modified-language          = [ remove-mod ] language

; 4. Subject declarations
; Empty "=" alone performs semantic reset
subject-decl      = "=" [ iri-ref / "#" fragment ]
fragment-decl     = "=#" fragment
object-decl       = "+" iri-ref
object-fragment-decl = "+#" fragment

; 5. Predicates
; No prefix = literal predicate, ? prefix = object predicate
predicate         = iri-ref           ; literal: value flows to predicate
object-predicate  = "?" iri-ref       ; object: value is object of predicate
reverse-predicate = "!" iri-ref       ; reverse: value is subject of predicate

; 6. Type declarations
type-decl = "." iri-ref

; 7. Literal modifiers
datatype = "^^" iri-ref
language = "@" langtag
langtag  = ALPHA *( ALPHA / DIGIT / "-" )

; 8. IRI references
iri-ref = curie / iri / fragment
curie   = prefix-name ":" reference
iri     = scheme ":" hier-part [ "?" query ] [ "#" fragment ]
scheme  = ALPHA *( ALPHA / DIGIT / "+" / "-" / "." )
hier-part = *( VCHAR )
query     = *( VCHAR )
fragment  = reference
reference = 1*( ALPHA / DIGIT / "-" / "_" / "." )

; 9. Value carriers (attachment points)
; Note: Markdown parsing itself is out of scope for ABNF

; 9.1 Inline carriers
emphasis-span   = "*" text "*" / "_" text "_"
strong-span     = "**" text "**" / "__" text "__"
code-span       = "`" text "`" / "``" text "``"
link-span       = "[" text "](" text ")" / "[" text "]"
image-span      = "!" "[" text "](" text ")"
url-span        = "<" iri ">"

inline-span = 
      emphasis-span
    / strong-span
    / code-span
    / link-span
    / image-span
    / url-span

; 9.2 Block carriers  
heading         = 1*6 "#" WSP text
paragraph       = 1*VCHAR
blockquote      = ">" WSP text

; Code fence: opening determines closing (3+ backticks or tildes)
code-fence      = backtick-fence / tilde-fence
backtick-fence  = backticks [ WSP info-string ] LF *( text / LF ) backticks
backticks       = 3*"`"                        ; 3 or more backticks
tilde-fence    = tildes [ WSP info-string ] LF *( text / LF ) tildes
tildes         = 3*"~"                        ; 3 or more tildes
info-string    = *( VCHAR / WSP )             ; language identifier, etc.

; 10. Lists (pure Markdown structure)

; 10.1 List items (explicit annotations only)
; List items are pure Markdown structure requiring explicit annotations
list-item = list-marker WSP text *WSP [ attrs-block ]
list-marker = "-" / "*" / "+" / 1*DIGIT "."

; 10.2 List block
; Lists are pure Markdown with no semantic propagation
list-block = list-item *( LF list-item / LF nested-list )

; 10.3 Nested list
; Nested lists have no semantic inheritance
nested-list = 1*WSP list-block

; 11. Standalone subject declarations
standalone-subject = *WSP "{=" ( iri-ref / "#" fragment ) "}" *WSP

; 12. Annotation attachment
; Note: predicate/object-predicate/reverse-predicate are mutually exclusive
; within a single annotation (one "of" relationship per annotation)
annotation =
      inline-span *WSP attrs-block
    / heading *WSP attrs-block
    / paragraph *WSP attrs-block
    / list-item
    / blockquote *WSP attrs-block
    / code-fence *WSP attrs-block
    / url-span *WSP attrs-block
    / standalone-subject

; 13. Grammar guarantees (normative)
; Attribute token order is semantically unordered
; Lists are pure Markdown structure with no semantic scope
; Nested lists establish a new semantic scope
; No implicit inheritance across list levels
; Deterministic, streaming-friendly parsing
; Round-trip safe (MD-LD <-> RDF <-> MD-LD)
; No semantic inference at syntax level

; 14. Forbidden constructs (not expressible in this grammar)
; - Blank nodes
; - Key-value pairs  
; - Nested attribute blocks
; - Implicit subjects/predicates
; - Structural inference
; - Semantic list propagation
