(* MD-LD EBNF Grammar (W3C/ISO 14977 compliant) *)
(* Version: 1.1 (2024-05-04) *)
(* Updated to match actual parser implementation *)
(* - Added remove polarity (- prefix) *)
(* - Added subject reset (= alone) *)
(* - Added prefix folding (CURIE in context declarations) *)
(* - Fixed predicate/objectPredicate distinction *)
(* - Fixed code fence matching (3+ backticks/tildes) *)
(* Defines syntax of MD-LD annotations embedded in CommonMark Markdown *)

(* 1. Lexical elements *)
letter        = "A".."Z" | "a".."z" ;
digit         = "0".."9" ;
hex           = digit | "A".."F" | "a".."f" ;
whitespace    = " " | "\t" ;
newline       = "\n" | "\r\n" ;
indent        = whitespace , whitespace+ ;
vchar         = ? any visible non-whitespace character ? ;
text          = { vchar | whitespace } ;

(* 2. Context declarations *)
contextDecl   = "[" , contextKey , "]" , whitespace , "<" , contextIri , ">" ;
contextKey    = "@vocab" | prefixName ;
prefixName    = letter , { letter | digit | "-" | "_" } ;

(* Prefix folding: IRI can be a CURIE referencing previously declared prefix *)
contextIri    = iri | curie ;

(* 3. Attribute block *)
attrsBlock    = "{" , whitespace* , attrsTokens? , whitespace* , "}" ;
attrsTokens   = attrsToken , { whitespace+ , attrsToken } ;

(* 4. Attribute tokens (all support optional remove polarity) *)
attrsToken   = 
      modifiedSubjectDecl
    | modifiedFragmentDecl
    | modifiedObjectDecl
    | modifiedObjectFragmentDecl
    | modifiedTypeDecl
    | modifiedPredicate
    | modifiedObjectPredicate
    | modifiedReversePredicate
    | modifiedDatatype
    | modifiedLanguage ;

(* Remove polarity modifier *)
removeMod   = "-" ;

(* Modified tokens with optional remove prefix *)
modifiedSubjectDecl      = [ removeMod ] , subjectDecl ;
modifiedFragmentDecl     = [ removeMod ] , fragmentDecl ;
modifiedObjectDecl       = [ removeMod ] , objectDecl ;
modifiedObjectFragmentDecl = [ removeMod ] , objectFragmentDecl ;
modifiedTypeDecl         = [ removeMod ] , typeDecl ;
modifiedPredicate        = [ removeMod ] , predicate ;
modifiedObjectPredicate  = [ removeMod ] , objectPredicate ;
modifiedReversePredicate   = [ removeMod ] , reversePredicate ;
modifiedDatatype         = [ removeMod ] , datatype ;
modifiedLanguage         = [ removeMod ] , language ;

(* 5. Subject and object declarations *)
(* Empty "=" alone performs semantic reset *)
subjectDecl   = "=" , [ iriRef | "#" , fragment ] ;
fragmentDecl  = "=#" , fragment ;
objectDecl    = "+" , iriRef ;
objectFragmentDecl = "+#" , fragment ;

(* 6. Predicates *)
(* No prefix = literal predicate, ? prefix = object predicate *)
predicate          = iriRef ;               (* literal: value flows to predicate *)
objectPredicate    = "?" , iriRef ;         (* object: value is object of predicate *)
reversePredicate   = "!" , iriRef ;         (* reverse: value is subject of predicate *)

(* 7. Type declaration *)
typeDecl      = "." , iriRef ;

(* 8. Literal modifiers *)
datatype      = "^^" , iriRef ;
language      = "@" , langTag ;
langTag       = letter , { letter | digit | "-" } ;

(* 9. CURIEs and IRIs *)
iriRef        = curie | iri | fragment ;
curie         = prefixName , ":" , reference ;
reference     = ( letter | digit ) , { letter | digit | "-" | "_" | "." } ;
iri           = scheme , ":" , hierPart , [ "?" , query ] , [ "#" , fragment ] ;
scheme        = letter , { letter | digit | "+" | "-" | "." } ;
hierPart      = { vchar } ;
query         = { vchar } ;
fragment      = reference ;

(* 10. Value carriers (Markdown attachment points) *)
(* Note: Markdown syntax itself is abstracted *)

(* 10.1 Inline carriers *)
emphasisSpan   = "*" , text , "*" | "_" , text , "_" ;
strongSpan     = "**" , text , "**" | "__" , text , "__" ;
codeSpan       = "`" , text , "`" | "``" , text , "``" ;
linkSpan       = "[" , text , "](" , text , ")" | "[" , text , "]" ;
imageSpan      = "!" , "[" , text , "](" , text , ")" ;
urlSpan        = "<" , iri , ">" ;

inlineSpan =
      emphasisSpan
    | strongSpan
    | codeSpan
    | linkSpan
    | imageSpan
    | urlSpan ;

(* 10.2 Block carriers *)
heading        = "#" , { "#" } , whitespace , text ;
paragraph      = vchar , { vchar | whitespace } ;
blockquote     = ">" , whitespace , text ;

(* Code fence: opening determines closing (3+ backticks or tildes) *)
codeFence      = backtickFence | tildeFence ;
backtickFence  = backticks , [ whitespace , infoString ] , newline , 
                 { text | newline } , backticks ;
backticks      = "`" , "`" , "`" , { "`" } ;     (* 3 or more backticks *)
tildeFence     = tildes , [ whitespace , infoString ] , newline , 
                 { text | newline } , tildes ;
tildes         = "~" , "~" , "~" , { "~" } ;     (* 3 or more tildes *)
infoString     = { vchar | whitespace } ;      (* language identifier, etc. *)

(* 11. Lists (pure Markdown structure) *)

(* 11.1 List items (explicit annotations only) *)
(* List items are pure Markdown structure requiring explicit annotations *)
listItem =
    listMarker , whitespace , text , whitespace* , attrsBlock? ;

listMarker =
      "-"
    | "*"
    | "+"
    | digit , { digit } , "." ;

(* 11.2 List block *)
(* Lists are pure Markdown with no semantic propagation *)
listBlock =
    listItem , { newline , listItem | nestedList } ;

(* 11.3 Nested list *)
(* Nested lists have no semantic inheritance *)
nestedList =
    indent , listBlock ;

(* 12. Standalone subject declarations *)
standaloneSubject =
    whitespace* , "{=" , ( iriRef | "#" , fragment ) , "}" , whitespace* ;

(* 13. Annotation attachment *)
(* Note: predicate/objectPredicate/reversePredicate are mutually exclusive *)
(* within a single annotation (one "of" relationship per annotation) *)
annotation =
      inlineSpan , whitespace* , attrsBlock
    | heading , whitespace* , attrsBlock
    | paragraph , whitespace* , attrsBlock
    | listItem
    | blockquote , whitespace* , attrsBlock
    | codeFence , whitespace* , attrsBlock
    | urlSpan , whitespace* , attrsBlock
    | standaloneSubject ;

(* 14. Grammar guarantees (normative) *)
(* Attribute token order is semantically unordered *)
(* Lists are pure Markdown structure with no semantic scope *)
(* Nested lists establish a new semantic scope *)
(* No implicit inheritance across list levels *)
(* Deterministic, streaming-friendly parsing *)
(* Round-trip safe (MD-LD ↔ RDF ↔ MD-LD) *)
(* No semantic inference at syntax level *)

(* 15. Forbidden constructs (not expressible in this grammar) *)
(* - Blank nodes *)
(* - Key-value pairs  *)
(* - Nested attribute blocks *)
(* - Implicit subjects/predicates *)
(* - Structural inference *)
(* - Semantic list propagation *)
